# --- Local Docker Compose ---
# Host port for the Dockerized customer web app (avoids conflict with pnpm dev:web on 3000).
WEB_HOST_PORT=3003

# --- Production: API (Spring Boot) ---
SPRING_PROFILES_ACTIVE=prod
DB_HOST=
DB_PORT=5432
DB_NAME=watchstore
DB_USER=
DB_PASSWORD=
# Option A: full Upstash URL (recommended on Render)
REDIS_URL=rediss://default:YOUR_TOKEN@YOUR-ENDPOINT.upstash.io:6379
# Option B: separate fields (host only — not the full rediss:// URL)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL_ENABLED=true
JWT_SECRET=
CORS_ORIGINS=https://www.example.com,https://admin.example.com
FRONTEND_WEB_URL=https://www.example.com
REFRESH_COOKIE_SECURE=true
REFRESH_COOKIE_SAME_SITE=None
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
S3_BUCKET=watch-store-images
AWS_REGION=us-east-1
# Leave empty for real AWS (uses default credential chain / IAM).
# Set to LocalStack URL for local dev only:
# S3_ENDPOINT=http://localstack:4566
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
OTEL_EXPORTER_OTLP_ENDPOINT=
TRACING_SAMPLING=0.1
# Stripe Test Mode (use sk_test_... and whsec_... from Stripe Dashboard / CLI)
STRIPE_ENABLED=true
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# --- Production: Vercel (apps/web and apps/admin) ---
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
# Optional: restrict Next.js image optimization to your S3/CloudFront host
S3_IMAGE_HOSTNAME=watch-store-images.s3.us-east-1.amazonaws.com
# Optional override (full base URL, e.g. https://watch-store-images.s3.us-east-1.amazonaws.com)
# NEXT_PUBLIC_S3_IMAGE_BASE_URL=
