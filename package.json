{
  "name": "watch-store",
  "private": true,
  "version": "0.1.0",
  "description": "Production-grade watch e-commerce monorepo",
  "scripts": {
    "dev:web": "pnpm --filter @watch-store/web dev",
    "dev:admin": "pnpm --filter @watch-store/admin dev",
    "build:web": "pnpm --filter @watch-store/web build",
    "build:admin": "pnpm --filter @watch-store/admin build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
